            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 Assertion" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper


def token = vars.get(&quot;v_token&quot;) //obtener token
def expectedUser = vars.get(&quot;V_USER&quot;) //variable de usuaruo

if (token &amp;&amp; token.contains(&quot;.&quot;)) {
    try {
        //separar componentes de token
        def parts = token.tokenize(&quot;.&quot;) 
        def payload = parts[1]
        
        //Decodificar Base64
        def decodedBytes = java.util.Base64.getUrlDecoder().decode(payload)
        def decoded = new String(decodedBytes, &quot;UTF-8&quot;)
        
        //parsear JSON y extraer el usuario [sub]
        def json = new JsonSlurper().parseText(decoded)
        def actualUser = json.sub 

        //validar
        if (actualUser != expectedUser) {
            AssertionResult.setFailure(true)
            AssertionResult.setFailureMessage(&quot;ERROR: Usuario en token es [${actualUser}], se esperaba [${expectedUser}]&quot;)
        }
    } catch (Exception e) {
        AssertionResult.setFailure(true)
        AssertionResult.setFailureMessage(&quot;Error procesando el token: &quot; + e.getMessage())
    }
} else {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;No se encontró un token válido en &apos;v_token&apos;&quot;)
}</stringProp>
            </JSR223Assertion>
